<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Voxen.Client.Features.ServerBrowser.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:CompileBindings="True"
             x:Class="Voxen.Client.Features.ServerBrowser.Views.AddServerDialogView"
             x:DataType="vm:AddServerDialogViewModel">
    <Design.DataContext>
        <vm:AddServerDialogViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="10">
        <TextBlock Text="Add server"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"/>
        <TextBox MinWidth="300"
                 Watermark="Hostname"
                 Text="{Binding Hostname}"/>
        <TextBox MinWidth="300"
                 Watermark="Port"
                 Text="{Binding Port}"/>
        <Button Content="Add"
                Foreground="White"
                Command="{Binding AddServerCommand}"/>
    </StackPanel>
</UserControl>
