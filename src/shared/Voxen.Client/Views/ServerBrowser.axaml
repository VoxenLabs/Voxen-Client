<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Voxen.Client.ViewModels"
             x:Class="Voxen.Client.Views.ServerBrowser"
             x:DataType="vm:ServerBrowserViewModel">

    <Border Background="#1E1F22">
        <StackPanel Spacing="10" Margin="10">

            <!-- Use ItemsSource with compiled binding -->
            <ItemsControl ItemsSource="{Binding Servers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Button Width="60" Height="60" CornerRadius="30"
                                Content="{Binding}"
                                HorizontalAlignment="Center"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add server button -->
            <Button Width="60" Height="60" CornerRadius="30"
                    Content="+"
                    Command="{Binding AddServerCommand}"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>

</UserControl>
